  "scripts": {
    "start": "react-scripts start",
    "prebuild": "node server.js",
    "build": "cross-env CI=false react-scripts build",
    "build:seo": "cross-env FORCE_PRERENDER=true npm run build",
    "postbuild": "node scripts/postbuild-prerender.js",
    "deploy:seo": "cross-env FORCE_PRERENDER=true npx vercel build && npx vercel deploy --prebuilt --prod",
    "test": "react-scripts test",
    "eject": "react-scripts eject"
  },
  "reactSnap": {
    "inlineCss": false,
    "skipThirdPartyRequests": true,
    "include": [
      "/",
      "/aboutus",
      "/nutrition/contact-us",
      "/nutrition/trainer-nutrition",
      "/nutrition/white-labelling",
      "/third-party-manufacturing/protein-powder",
      "/third-party-manufacturing/sports-nutrition-supplements",
      "/white-labelling-blogs"
    ]
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@babel/plugin-proposal-private-property-in-object": "^7.21.11",
    "cross-env": "^7.0.3",
